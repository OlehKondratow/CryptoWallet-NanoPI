# --- Новые правила для очистки репозитория ---

# Игнорируем временные файлы и логи внутри nfsroot
**/nfsroot/var/log/*
**/nfsroot/var/run/*
**/nfsroot/var/tmp/*
**/nfsroot/var/lock/*
**/nfsroot/var/lib/*
**/nfsroot/run/*
**/nfsroot/tmp/*
**/nfsroot/etc/volatile.cache

# Игнорируем SSH ключи (безопасность + отсутствие шума)
**/nfsroot/etc/ssh/ssh_host_*_key*

# Игнорируем конфигурацию DNS (часто меняется при загрузке)
**/nfsroot/etc/resolv.conf